# runtime data (ingested) — never commit; lives on panza / deploy target
data/
*.db
*.db-*
*.sqlite

# auxiliary binaries (e.g. the vendored node for Lolipop CGI)
bin/

# node
node_modules/
npm-debug.log*

# secrets / local config
*.local.toml
*.local.json
.env
.env.*

# build output (bundled CGI + assembled deploy tree)
dist/
build/
# esbuild bundle of editor/main.js — regenerated by `npm run bundle` (stage.sh)
public/compose-editor.js
